<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">
    <ImageView
        android:id="@+id/image_view_add_detailed_transaction_item_delete"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/baseline_delete_24"
        android:contentDescription="Remove Item"
        android:layout_gravity="end"
        android:visibility="gone"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Amount"/>
    <EditText
        android:id="@+id/edit_text_add_detailed_transaction_item_amount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="numberDecimal"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Description"/>
    <EditText
        android:id="@+id/edit_text_add_detailed_transaction_item_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Category"/>
    <Spinner
        android:id="@+id/spinner_add_detailed_transaction_item_category"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <TextView
        android:id="@+id/text_view_add_detailed_transaction_show_details"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Details"/>
    <LinearLayout
        android:id="@+id/linear_layout_add_detailed_transaction_details"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:animateLayoutChanges="true"
        android:visibility="gone">
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Brand"/>
    <EditText
        android:id="@+id/edit_text_add_detailed_transaction_item_brand"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Variation"/>
    <EditText
        android:id="@+id/edit_text_add_detailed_transaction_item_variation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. XL, 500g, Chocolate"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Quantity"/>
    <EditText
        android:id="@+id/edit_text_add_detailed_transaction_item_quantity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="number"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reference Number"/>
    <EditText
        android:id="@+id/edit_text_add_detailed_transaction_item_reference"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerview_add_detailed_transaction_item_images"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1" />
        <ImageView
            android:id="@+id/image_view_add_detailed_transaction_item_add_image"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="Add image to item"
            android:src="@drawable/baseline_add_photo_alternate_24"/>
    </LinearLayout>
    </LinearLayout>
</LinearLayout>