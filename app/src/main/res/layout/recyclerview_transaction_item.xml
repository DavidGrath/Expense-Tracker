<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="8dp"
    android:layout_marginHorizontal="8dp"
    android:background="@drawable/partial_border_middle">
    <Button
        android:id="@+id/image_view_transaction_item_category"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:icon="@drawable/material_symbols_restaurant_48px"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        style="@style/Widget.App.Button.ContainedButton.IconOnly"/>
    <TextView
        android:id="@+id/text_view_transaction_item_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        tools:text="Lorem ipsum dolor sit amet, consectetur adipiscing elit."
        android:maxLines="2"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toEndOf="@id/image_view_transaction_item_category"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/image_view_transaction_item_first_image"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"/>
    <TextView
        android:id="@+id/text_view_transaction_item_store"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="KFC"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toStartOf="@id/text_view_transaction_item_description"
        app:layout_constraintTop_toBottomOf="@id/text_view_transaction_item_description"
        app:layout_constraintEnd_toStartOf="@id/image_view_transaction_item_first_image"/>
    <ImageView
        android:id="@+id/image_view_transaction_item_first_image"
        android:layout_width="56dp"
        android:layout_height="56dp"
        app:layout_constraintEnd_toStartOf="@id/text_view_transaction_item_amount"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:src="@tools:sample/avatars"
        tools:visibility="gone"
        android:contentDescription="Main Image" />
    <TextView
        android:id="@+id/text_view_transaction_item_amount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="USD 20.00" />

</androidx.constraintlayout.widget.ConstraintLayout>