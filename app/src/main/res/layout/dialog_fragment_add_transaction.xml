<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">
    <EditText
        android:id="@+id/edit_text_add_transaction_amount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Amount"
        android:inputType="numberDecimal"/>
    <EditText
        android:id="@+id/edit_text_add_transaction_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Description" />
    <Spinner
        android:id="@+id/spinner_add_transaction_category"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
    <Spinner
        android:id="@+id/spinner_add_transaction_account"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
</LinearLayout>