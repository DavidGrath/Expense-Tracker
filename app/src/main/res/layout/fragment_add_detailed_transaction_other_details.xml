<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:animateLayoutChanges="true">

        <CheckBox
            android:id="@+id/check_box_add_detailed_transaction_use_custom_date_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Custom Date/Time"/>
        <LinearLayout
            android:id="@+id/linear_layout_add_detailed_transaction_date_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="visible"
            android:animateLayoutChanges="true">
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_weight="1">
                <TextView
                    android:id="@+id/text_view_add_detailed_transaction_custom_date"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:drawableStart="@drawable/baseline_calendar_today_24"
                    android:text="2025-06-30"
                    android:layout_weight="1"/>
                <ImageView
                    android:id="@+id/image_view_add_detailed_transaction_custom_date_remove"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/baseline_cancel_24"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_weight="1">
                <TextView
                    android:id="@+id/text_view_add_detailed_transaction_custom_time"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:drawableStart="@drawable/baseline_access_alarm_24"
                    android:text="08:00"
                    android:layout_weight="1"/>
                <ImageView
                    android:id="@+id/image_view_add_detailed_transaction_custom_time_remove"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/baseline_cancel_24"/>
            </LinearLayout>
        </LinearLayout>
        <TextView
            android:id="@+id/text_view_add_detailed_transaction_zone_difference_notice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:drawableStart="@drawable/baseline_info_24"
            android:text="Transaction time zone not same as local time zone"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TODO Seller" />

        <Spinner
            android:id="@+id/spinner_add_detailed_transaction_account"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Note" />
        <TextView
            android:id="@+id/text_view_add_detailed_transaction_note_length_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/300" />
        </LinearLayout>
        <EditText
            android:id="@+id/edit_text_add_detailed_transaction_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lines="5"
            android:inputType="textMultiLine"/>
        <TextView
            android:id="@+id/text_view_add_detailed_transaction_add_evidence"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Evidence"
            android:drawableRight="@drawable/baseline_add_24"/>


        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerview_add_detailed_transaction_evidence"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>