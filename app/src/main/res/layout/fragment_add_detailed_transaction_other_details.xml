<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TODO Time" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TODO Seller" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TODO Account" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TODO Currency, maybe move currency to account" />


        <TextView
            android:id="@+id/text_view_add_detailed_transaction_add_evidence"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Evidence"
            android:drawableRight="@drawable/baseline_add_24"/>


        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerview_add_detailed_transaction_evidence"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>