<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <TextView
        android:id="@+id/text_view_account_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toStartOf="@id/image_view_account_edit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:text="Account Name"/>
    <TextView
        android:id="@+id/text_view_account_currency_code"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_view_account_name"
        app:layout_constraintEnd_toStartOf="@id/image_view_account_edit"
        android:text="Currency Name (CUR)"/>
    <TextView
        android:id="@+id/text_view_account_expenses"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_view_account_currency_code"
        app:layout_constraintEnd_toStartOf="@id/text_view_account_income"
        android:drawableStart="@drawable/baseline_remove_24"
        android:text="100.00"/>
    <TextView
        android:id="@+id/text_view_account_income"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toEndOf="@id/text_view_account_expenses"
        app:layout_constraintTop_toBottomOf="@id/text_view_account_currency_code"
        app:layout_constraintEnd_toStartOf="@id/image_view_account_edit"
        android:drawableStart="@drawable/baseline_add_24"
        android:text="100.00"/>
    <TextView
        android:id="@+id/text_view_account_transaction_count"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/text_view_account_expenses"
        app:layout_constraintEnd_toStartOf="@id/text_view_account_item_count"
        android:text="2 transactions"/>
    <TextView
        android:id="@+id/text_view_account_item_count"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toEndOf="@id/text_view_account_transaction_count"
        app:layout_constraintTop_toBottomOf="@id/text_view_account_expenses"
        app:layout_constraintEnd_toStartOf="@id/image_view_account_edit"
        android:text="5 items"/>
    <ImageView
        android:id="@+id/image_view_account_edit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/baseline_edit_24"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>
    <ImageView
        android:id="@+id/image_view_account_view_stats"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@drawable/baseline_bar_chart_24"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/image_view_account_edit"
        app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>