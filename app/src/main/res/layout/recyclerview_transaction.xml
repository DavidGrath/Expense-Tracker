<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">
    <ImageView
        android:id="@+id/image_view_transaction_category"
        android:layout_width="24dp"
        android:layout_height="24dp"
        tools:src="@drawable/baseline_restaurant_24"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>
    <TextView
        android:id="@+id/text_view_transaction_description"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="Chicken"
        app:layout_constraintStart_toEndOf="@id/image_view_transaction_category"
        app:layout_constraintTop_toTopOf="parent" />
    <TextView
        android:id="@+id/text_view_transaction_store"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="KFC"
        app:layout_constraintStart_toStartOf="@id/text_view_transaction_description"
        app:layout_constraintTop_toBottomOf="@id/text_view_transaction_description" />

    <TextView
        android:id="@+id/text_view_transaction_amount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="USD 20.00" />
</androidx.constraintlayout.widget.ConstraintLayout>