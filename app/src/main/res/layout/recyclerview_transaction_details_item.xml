<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools">
    <ImageView
        android:id="@+id/image_view_transaction_details_item_category"
        android:layout_width="64dp"
        android:layout_height="64dp"
        tools:src="@drawable/baseline_category_24"
        app:layout_constraintTop_toBottomOf="@id/text_view_transaction_details_item_price"
        app:layout_constraintEnd_toEndOf="parent"/>
    <TextView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        tools:text="Miscellaneous"
        app:layout_constraintTop_toBottomOf="@id/image_view_transaction_details_item_category"
        app:layout_constraintStart_toStartOf="@id/image_view_transaction_details_item_category"
        app:layout_constraintEnd_toEndOf="@id/image_view_transaction_details_item_category"/>
    <TextView
        android:id="@+id/text_view_transaction_details_item_price"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="24sp"
        tools:text="USD 20.00"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:id="@+id/text_view_transaction_details_item_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/text_view_transaction_details_item_price"
        android:layout_marginEnd="8dp"/>
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/text_view_transaction_details_item_description"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/image_view_transaction_details_item_category">
    <TextView
        android:id="@+id/text_view_transaction_details_item_variation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:text="Chocolate"/>
    <TextView
        android:id="@+id/text_view_transaction_details_item_brand"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:text="Generic"/>
    <TextView
        android:id="@+id/text_view_transaction_details_item_reference_number"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:text="1234-5678-abcd"/>
    <TextView
        android:id="@+id/text_view_transaction_details_item_quantity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:text="12" />
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view_transaction_details_item_images"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>