<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="56dp"
    android:layout_height="56dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <ImageView
        android:id="@+id/image_view_item_image_main"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <ImageView
        android:id="@+id/image_view_item_image_selected_indicator"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginStart="-8dp"
        android:layout_marginTop="-8dp"
        android:src="@drawable/baseline_cancel_24"
        app:layout_constraintStart_toEndOf="@id/image_view_item_image_main"
        app:layout_constraintTop_toTopOf="@id/image_view_item_image_main" />
</androidx.constraintlayout.widget.ConstraintLayout>